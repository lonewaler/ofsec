# ──────────────────────────────────────────────
# OfSec V3 — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ─── Database ─────────────────────────────────
POSTGRES_DB=ofsec
POSTGRES_USER=ofsec
POSTGRES_PASSWORD=ofsec_secret
DATABASE_URL=postgresql+asyncpg://ofsec:ofsec_secret@localhost:5432/ofsec

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant Vector DB ────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ─── Security ─────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
API_KEY=your-admin-api-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── LLM / AI ────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
OLLAMA_BASE_URL=http://localhost:11434

# ─── OSINT API Keys ──────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
PASSIVETOTAL_API_KEY=
BINARYEDGE_API_KEY=

# ─── Observability ────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:9090

# ─── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
