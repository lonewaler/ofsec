# ─── OfSec V3 — Environment Template ──────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# ─── App ──────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEBUG=true                       # Set false in production
SECRET_KEY=change-me-in-production
API_KEY=dev-api-key

# ─── Database ─────────────────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./ofsec.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://ofsec:STRONG_PASSWORD@localhost:5432/ofsec

POSTGRES_DB=ofsec
POSTGRES_USER=ofsec
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI / LLM ─────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── OSINT APIs ───────────────────────────────────────────────────
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
NVD_API_KEY=
OTX_API_KEY=
HUNTER_API_KEY=

# ─── Observability ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:9090
OTEL_SERVICE_NAME=ofsec-backend
