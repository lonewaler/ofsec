# ─── OfSec V3 — Environment Template ──────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# ─── App ──────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEBUG=true                       # Set false in production
SECRET_KEY=change-me-in-production
API_KEY=dev-api-key
LOG_LEVEL=INFO
VERSION=3.0.0

# ─── Database Pool ────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ─── CORS / Hosts ────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:8000"]
ALLOWED_HOSTS=["*"]

# ─── Database ─────────────────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./ofsec.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://ofsec:STRONG_PASSWORD@localhost:5432/ofsec

POSTGRES_DB=ofsec
POSTGRES_USER=ofsec
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI / LLM ─────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── OSINT APIs ───────────────────────────────────────────────────
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
NVD_API_KEY=
OTX_API_KEY=
HUNTER_API_KEY=

# ─── Observability ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:9090
OTEL_SERVICE_NAME=ofsec-backend
